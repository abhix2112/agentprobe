# agentprobe — sample environment. Copy to `.env` and fill in.
# `.env` is gitignored; this `.env.example` is committed as the reference.

# ─── Secrets ────────────────────────────────────────────────────────────────
# Used in THREE places, all of which read it from the process environment:
#   1. engine /generate   — LLM-backed adversarial test generation
#   2. engine /score       — the per-test sonnet judge
#   3. the agent-under-test — the local-mode sandbox runner inherits the
#      orchestrator's full env, so the cloned agent's own LLM calls use this key.
# If unset, /generate and /score fall back to deterministic offline paths, and
# the agent-under-test will fail its real LLM calls (→ an errored run).
ANTHROPIC_API_KEY=sk-ant-...

# Only needed by agents whose tools call other services (e.g. the official
# langchain-ai/react-agent uses Tavily search). Any secret set here is inherited
# by the sandbox runner, so the agent's tools can use it. Leave unset otherwise.
# TAVILY_API_KEY=tvly-...

# Only needed for AGENTPROBE_SANDBOX=e2b (the cloud sandbox path).
# E2B_API_KEY=e2b_...

# ─── Orchestrator ────────────────────────────────────────────────────────────
DATABASE_URL=postgres://agentprobe:agentprobe@localhost:5432/agentprobe
ENGINE_URL=http://127.0.0.1:8000

# Sandbox execution mode: mock (default, key-free) | local | e2b
AGENTPROBE_SANDBOX=local
# Local mode: a Python interpreter that has the AGENT-UNDER-TEST's dependencies
# (e.g. langgraph + langchain-anthropic). The runner is invoked with this python.
AGENTPROBE_LOCAL_PYTHON=/path/to/agent-venv/bin/python
# Where repos are cloned per run (a local path is copied; a URL is git-cloned).
AGENTPROBE_WORK_DIR=/tmp/agentprobe-clones
# Bounded concurrency for per-test sandbox execution (E2B Hobby ceiling is 20).
AGENTPROBE_SANDBOX_CONCURRENCY=5
# Hard per-run ceiling on total LLM calls (generate + judge across all agents).
AGENTPROBE_MAX_LLM_CALLS=50

# ─── Frontend (Vite dev server proxy → orchestrator) ─────────────────────────
ORCHESTRATOR_URL=http://127.0.0.1:8080
